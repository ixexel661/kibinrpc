{
	"name": "kibinrpc",
	"private": true,
	"type": "module",
	"version": "0.0.2",
	"scripts": {
		"build": "pnpm -r run build",
		"dev": "pnpm -r --parallel run dev",
		"dev:docs": "pnpm --filter docs dev",
		"example:node": "pnpm --filter @examples/node dev",
		"example:backend": "pnpm --filter @app/backend dev",
		"example:frontend": "pnpm --filter @app/frontend dev",
		"example:tanstack-query": "pnpm --filter @examples/tanstack-query dev",
		"check": "biome check",
		"check:fix": "biome check --write",
		"lint": "biome lint",
		"format": "biome format",
		"test": "pnpm run test:unit && pnpm run test:e2e",
		"test:unit": "pnpm --filter './packages/*' --filter '@examples/node' run test",
		"test:server": "pnpm --filter @kibinrpc/server run test",
		"test:client": "pnpm --filter @kibinrpc/client run test",
		"test:node": "pnpm --filter @examples/node run test",
		"test:e2e": "pnpm --filter @app/frontend run test:e2e",
		"release:bump": "bumpp packages/*/package.json apps/cli/package.json --no-push",
		"release": "pnpm run release:bump && pnpm run build && pnpm --filter './packages/*' publish && pnpm --filter kibinrpc publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@playwright/test": "^1.60.0",
		"bumpp": "^11.1.0",
		"lefthook": "^2.1.8",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@11.2.2"
}
