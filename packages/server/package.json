{
	"name": "@kibin/server",
	"version": "0.0.1",
	"description": "Framework-agnostic RPC server router with full type inference",
	"license": "MIT",
	"author": "ixexel661",
	"repository": {
		"type": "git",
		"url": "https://github.com/ixexel661/kibin",
		"directory": "packages/server"
	},
	"keywords": ["rpc", "server", "typescript", "web-api", "hono"],
